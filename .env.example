# API keys — environment only, never in config.json, never committed.
# Only set the ones you use; keyless providers are skipped silently.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
APIFY_TOKEN=

# Host paths for the compose volumes (defaults: ./vault and ./CaptureInbox)
VAULT_DIR=
INBOX_DIR=

# Cloudflare tunnel token — only needed for `docker compose --profile tunnel`
TUNNEL_TOKEN=
